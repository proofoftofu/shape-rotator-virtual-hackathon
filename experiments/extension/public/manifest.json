{
  "manifest_version": 3,
  "name": "U2SSO Extension Experiment",
  "version": "0.1.0",
  "description": "React and Tailwind popup that reuses the logic experiment to generate U2SSO registration and login payloads.",
  "permissions": ["storage", "tabs"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/contentBridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["artifacts/semaphore-2.wasm", "artifacts/semaphore-2.zkey"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "U2SSO Experiment",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
